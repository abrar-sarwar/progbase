# NextAuth (Auth.js v5)
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth 2.0 client — from Google Cloud Console → APIs & Services → Credentials
# Client ID format: <digits>-<32-char-hash>.apps.googleusercontent.com (note the DASH)
# In the OAuth client's "Authorized redirect URIs" add:
#   http://localhost:3000/api/auth/callback/google
#   http://localhost:3001/api/auth/callback/google   (fallback if :3000 is taken)
#   https://<your-vercel-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated e-board Gmail addresses. Empty = block everyone (fail-closed).
ALLOWED_EMAILS=
